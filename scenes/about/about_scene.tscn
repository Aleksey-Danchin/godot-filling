[ext_resource type="Texture2D" path="res://assets/Prinbles_Asset_Robin (v 1.1) (9_5_2023)/png/Counter/Default.png" id="3_card"]

[sub_resource type="StyleBoxTexture" id="card_style"]
texture = ExtResource("3_card")
texture_margin_left = 20.0
texture_margin_top = 16.0
texture_margin_right = 20.0
texture_margin_bottom = 16.0
content_margin_left = 40.0
content_margin_top = 36.0
content_margin_right = 40.0
content_margin_bottom = 36.0

[node name="AboutPanel" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_about")

[node name="Layout" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -360.0
offset_top = -420.0
offset_right = 360.0
offset_bottom = 420.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 24

[node name="BackButton" type="Button" parent="Layout"]
custom_minimum_size = Vector2(0, 96)
layout_mode = 2
theme = ExtResource("2_robin")
theme_override_font_sizes/font_size = 40
text = "← Об игре"

[node name="AboutCard" type="PanelContainer" parent="Layout"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_styles/panel = SubResource("card_style")

[node name="CardMargin" type="MarginContainer" parent="Layout/AboutCard"]
layout_mode = 2

[node name="VBox" type="VBoxContainer" parent="Layout/AboutCard/CardMargin"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="Description" type="Label" parent="Layout/AboutCard/CardMargin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Filling — головоломка в духе Flood It. Заливайте связанные клетки одного цвета, пока всё поле не станет однотонным. Чем меньше ходов — тем лучше."
autowrap_mode = 3

[node name="Author" type="Label" parent="Layout/AboutCard/CardMargin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 26
text = "Автор: (заглушка) Команда Filling"
autowrap_mode = 3

[node name="AuthorLink" type="Button" parent="Layout/AboutCard/CardMargin/VBox"]
custom_minimum_size = Vector2(0, 88)
layout_mode = 2
size_flags_horizontal = 3
theme = ExtResource("2_robin")
theme_override_font_sizes/font_size = 36
text = "Сайт автора (заглушка)"

[connection signal="pressed" from="Layout/BackButton" to="." method="_on_back_pressed"]
[connection signal="pressed" from="Layout/AboutCard/CardMargin/VBox/AuthorLink" to="." method="_on_author_link_pressed"]
